-- Generated by themectl: {{theme_id}}
local function apply_theme()
  local ok, payload = pcall(require, "themectl.palette")
  if not ok or type(payload) ~= "table" or type(payload.colors) ~= "table" then
    return
  end

  local c = payload.colors
  local set = vim.api.nvim_set_hl

  local function hl(name, spec)
    pcall(set, 0, name, spec)
  end

  hl("Normal", { fg = c.fg, bg = c.bg })
  hl("NormalFloat", { fg = c.fg, bg = c.bg_elevated })
  hl("SignColumn", { fg = c.fg_muted, bg = c.bg })
  hl("LineNr", { fg = c.line_nr, bg = c.bg })
  hl("CursorLineNr", { fg = c.line_nr_active, bg = c.bg, bold = true })
  hl("CursorLine", { bg = c.bg_elevated })
  hl("Visual", { bg = c.visual })
  hl("Pmenu", { fg = c.fg, bg = c.bg_elevated })
  hl("PmenuSel", { fg = c.bg, bg = c.accent })
  hl("Comment", { fg = c.suggestion, italic = true })
  hl("NonText", { fg = c.fg_muted })
  hl("VertSplit", { fg = c.bg_elevated, bg = c.bg })
  hl("WinSeparator", { fg = c.bg_elevated, bg = c.bg })
  hl("DiagnosticError", { fg = c.error })
  hl("DiagnosticWarn", { fg = c.warn })
  hl("DiagnosticInfo", { fg = c.info })
  hl("DiagnosticHint", { fg = c.ok })
end

_G.themectl_apply_theme = apply_theme

vim.api.nvim_create_autocmd({ "ColorScheme", "VimEnter", "FocusGained" }, {
  callback = function()
    apply_theme()
  end,
})

apply_theme()
